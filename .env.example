# Vercel Postgres — copy to .env.local and fill in your values.
# These are provided automatically when you link a Vercel Postgres
# (or Neon) database in the Vercel dashboard under Storage → your DB → .env.local

POSTGRES_URL="postgres://user:password@host/dbname?sslmode=require"
POSTGRES_URL_NON_POOLING="postgres://user:password@host/dbname?sslmode=require"
POSTGRES_PRISMA_URL="postgres://user:password@host/dbname?sslmode=require&pgbouncer=true"
POSTGRES_USER="user"
POSTGRES_HOST="host"
POSTGRES_PASSWORD="password"
POSTGRES_DATABASE="dbname"
